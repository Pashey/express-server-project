{
  "name": "backend-course-project",
  "version": "1.0.0",
  "description": "Quiz API with Express and Prisma",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:setup": "set DATABASE_URL=mysql://root:Oluchi@localhost:3306/quiz_app_test && npx prisma migrate deploy",
    "test:coverage": "vitest run --coverage"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": ["express", "prisma", "quiz"],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^5.1.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.1",
    "dotenv": "^16.4.7",
    "prisma": "^6.19.3",
    "supertest": "^7.0.0",
    "vitest": "^3.1.1"
  }
}